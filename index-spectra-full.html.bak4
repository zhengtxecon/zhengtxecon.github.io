<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Reveal on Scroll
        const reveals = document.querySelectorAll('.reveal');
        const revealOnScroll = () => {
            const windowHeight = window.innerHeight;
            const elementVisible = 100;
            reveals.forEach((reveal) => {
                const elementTop = reveal.getBoundingClientRect().top;
                if (elementTop < windowHeight - elementVisible) {
                    reveal.classList.add('active');
                }
            });
        };
        window.addEventListener('scroll', revealOnScroll);
        revealOnScroll();

        // Canvas Iridescence Effect (SPECTRA Style - Mint/Cyan)
        const canvas = document.getElementById('iridescence-canvas');
        if (canvas) {
            const ctx = canvas.getContext('2d');
            let w, h;
            let time = 0;

            function resize() {
                w = canvas.width = window.innerWidth;
                h = canvas.height = window.innerHeight;
            }
            resize();
            window.addEventListener('resize', resize);

            // Noise function (simplified Perlin-like)
            function noise(x, y, t) {
                return Math.sin(x * 0.002 + t * 0.3) * 
                       Math.cos(y * 0.002 + t * 0.3) * 
                       Math.sin((x + y) * 0.001 + t * 0.2);
            }

            // Draw dot matrix overlay
            function drawDotMatrix() {
                const dotSize = 2;
                const spacing = 8;
                ctx.fillStyle = 'rgba(100, 200, 200, 0.08)';
                
                for (let x = 0; x < w; x += spacing) {
                    for (let y = 0; y < h; y += spacing) {
                        const opacity = 0.03 + Math.abs(noise(x, y, time * 0.5)) * 0.05;
                        ctx.globalAlpha = opacity;
                        ctx.beginPath();
                        ctx.arc(x, y, dotSize, 0, Math.PI * 2);
                        ctx.fill();
                    }
                }
                ctx.globalAlpha = 1;
            }

            function draw() {
                time += 0.003; // Slower animation
                
                // Clear with transparent background (let base color show through)
                ctx.clearRect(0, 0, w, h);
                
                // Add flowing light bands (aurora effect) - brighter colors
                for (let i = 0; i < 4; i++) {
                    const offsetX = Math.sin(time * 0.4 + i * 1.5) * w * 0.4;
                    const offsetY = Math.cos(time * 0.25 + i * 1.5) * h * 0.4;
                    const size = 500 + Math.sin(time * 0.3 + i) * 200;
                    
                    const blobGradient = ctx.createRadialGradient(
                        w * 0.5 + offsetX, h * 0.3 + offsetY, 0,
                        w * 0.5 + offsetX, h * 0.3 + offsetY, size
                    );
                    
                    // Brighter mint/cyan/white variations
                    const colors = [
                        [200, 240, 240],  // Very light mint
                        [180, 235, 240],  // Light cyan
                        [160, 230, 235],  // Light turquoise
                        [190, 238, 242]   // Light aqua
                    ];
                    const [r, g, b] = colors[i];
                    
                    const alpha = 0.25 + noise(i * 100, i * 100, time) * 0.1;
                    blobGradient.addColorStop(0, `rgba(${r}, ${g}, ${b}, ${alpha})`);
                    blobGradient.addColorStop(0.4, `rgba(${r}, ${g}, ${b}, ${alpha * 0.5})`);
                    blobGradient.addColorStop(0.7, `rgba(${r}, ${g}, ${b}, ${alpha * 0.2})`);
                    blobGradient.addColorStop(1, 'rgba(255, 255, 255, 0)');
                    
                    ctx.fillStyle = blobGradient;
                    ctx.fillRect(0, 0, w, h);
                }
                
                // Add subtle dot matrix texture
                drawDotMatrix();
                
                requestAnimationFrame(draw);
            }
            
            draw();
        }
    });
</script>

</body>
</html>